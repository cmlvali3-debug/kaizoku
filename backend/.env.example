# ============================================================
# OITAKU IMPORT — .env.example
# Copy this file to .env and fill in your values
# On Railway: add these in the "Variables" tab of your service
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080  # Replace with your Vercel URL

# ── DATABASE (Railway Postgres — auto-filled on Railway) ─────
DATABASE_URL=postgresql://user:password@host:5432/oitaku

# ── YAHOO JAPAN API ──────────────────────────────────────────
# Get at: https://developer.yahoo.co.jp → Create App → Auction API
YAHOO_JP_APP_ID=
YAHOO_JP_SECRET=

# ── BE FORWARD API ───────────────────────────────────────────
# Request at: api@beforward.jp (mention Oitaku Import, France, reseller)
# Approval time: 3-7 business days
BEFORWARD_API_KEY=

# ── GOO-NET EXCHANGE ─────────────────────────────────────────
# Request at: https://www.goo-net-exchange.com/partner
# Approval time: 5-10 business days
GOONET_API_TOKEN=

# ── ENCAR (KOREA) ────────────────────────────────────────────
# No key required for basic access
# Optional B2B key for higher rate limits:
ENCAR_API_KEY=

# ── ALERTS / EMAIL ───────────────────────────────────────────
# Optional: SendGrid for email alerts when a matching car appears
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@oitakuimport.fr
